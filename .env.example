# Resend (transactional email)
RESEND_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — Project Settings → API → service_role / secret key (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Korapay (ticket payments — static payment link flow)
# Shared secret key for payment verification (same key as your primary Korapay app)
KORAPAY_SECRET_KEY=
# Max fee pass-through Korapay adds at checkout (default 1.5%). Raise if bank transfer fees are higher.
# KORAPAY_FEE_TOLERANCE_RATE=0.04
# Tier-specific Korapay payment links (fixed early bird amounts in dashboard)
KORAPAY_LINK_STANDARD=https://checkout.korapay.com/pay/StandardPass
KORAPAY_LINK_EXECUTIVE=https://checkout.korapay.com/pay/ExecutivePass
KORAPAY_LINK_INSTITUTIONAL=https://checkout.korapay.com/pay/Institutional
KORAPAY_LINK_GROUP=https://checkout.korapay.com/pay/Group
# Fallback variable-amount link (only used for unknown tiers)
# KORAPAY_PAYMENT_LINK_URL=https://checkout.korapay.com/pay/dice2026
# Forward webhook events from your primary app (single Korapay webhook URL constraint)
TICKET_WEBHOOK_FORWARD_SECRET=

# Optional overrides
# RESEND_FROM_EMAIL="DICE 2026 <info@dice2026.africa>"
# RESEND_NOTIFY_EMAIL=info@dice2026.africa
# EMAIL_LOGO_URL=https://dice2026.africa/images/logos/dilogo2026_white.png
